# =============================================================================
# kivora-deploy.env.example
# =============================================================================
# Copy this file to kivora-deploy.env and fill in your real values.
# NEVER commit kivora-deploy.env to git — it contains secret keys.
#
#   cp kivora-deploy.env.example kivora-deploy.env
#   # Then edit kivora-deploy.env
# =============================================================================

# -----------------------------------------------------------------------------
# BUILD-TIME env vars (these get INLINED into the client JS bundle)
# -----------------------------------------------------------------------------
# Required. Without these, Supabase auth (Google sign-in) will be broken
# because lib/supabase.js will set supabasePublic = null.
NEXT_PUBLIC_SUPABASE_URL=https://asfzdbpfakwpiawhhrby.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR_ANON_KEY_HERE

# Optional: also a build-time NEXT_PUBLIC var (only needed if your code uses it)
# NEXT_PUBLIC_APP_URL=https://kivora.pages.dev

# -----------------------------------------------------------------------------
# DEPLOY-TIME env vars (used by wrangler to upload to Cloudflare Pages)
# -----------------------------------------------------------------------------
# Required. Create a CF API token with "Cloudflare Pages — Edit" permission.
# https://dash.cloudflare.com/profile/api-tokens
CF_API_TOKEN=cf_your_api_token_here
# Optional but recommended: your Cloudflare account ID (found in dashboard URL)
CF_ACCOUNT_ID=your_account_id_here

# -----------------------------------------------------------------------------
# SERVER-SIDE env vars (runtime-only — NOT inlined into client bundle)
# These are READ AT RUNTIME by the deployed Cloudflare Pages worker.
# They MUST ALSO be set on the CF Pages dashboard → Settings → Environment Variables,
# because the deployed worker reads them from there, not from this file.
# Listing them here is useful for local dev (`bun run dev`) — but for production,
# set them on the dashboard.
# -----------------------------------------------------------------------------

# Required for server-side Supabase queries (auth, credits, billing, etc.)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR_SERVICE_ROLE_KEY_HERE

# AI providers
GROQ_API_KEY=gsk_your_groq_key_here
GROQ_API_KEY_FALLBACK=gsk_your_groq_fallback_key_here
GROQ_PROXY_URL=https://kivora-groq-proxy.vercel.app/api/groq
GEMINI_API_KEY=your_gemini_key_here
OPENROUTER_API_KEY=sk-or-your_openrouter_key_here
MISTRAL_API_KEY=your_mistral_key_here
MISTRAL_API_KEY_FALLBACK=your_mistral_fallback_key_here
ZAI_API_KEY=your_zai_key_here
ZAI_BASE_URL=https://api.z.ai/api/paas/v4
ZAI_USER_ID=your_zai_user_id_here

# Search / news APIs
TAVILY_API_KEY=tvly_your_tavily_key_here
BRAVE_SEARCH_API_KEY=your_brave_key_here
NEWSAPI_KEY=your_newsapi_key_here
NEWSDATA_KEY=your_newsdata_key_here
FIRECRAWL_API_KEY=fc-your_firecrawl_key_here
ALPHAVANTAGE_KEY=your_alphavantage_key_here
PIXABAY_KEY=your_pixabay_key_here

# Sandbox / Daytona
DAYTONA_API_KEY=your_daytona_key_here
DOCKER_HOST_URL=https://your_docker_host_here
KIVORA_SANDBOX_KEY=your_sandbox_key_here
KIVORA_SANDBOX_URL=https://your_sandbox_url_here

# Paystack billing (only needed when billing features are deployed)
# PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_here
