# =============================================================================
# Kivora Voice Server - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# ── Required ──
# Hugging Face token (needed for Pyannote diarization + gated models)
# Get yours at: https://huggingface.co/settings/tokens
HF_TOKEN=

# ── Optional: API Security ──
# Set to "true" to require X-API-Key header on all requests
OMNIVOICE_AUTH_ENABLED=false
# The API key clients must send (only used if AUTH_ENABLED=true)
OMNIVOICE_API_KEY=

# ── Optional: Server Configuration ──
# Port to listen on (default: 3900, cloud platforms auto-set PORT)
PORT=3900
# Where to store models and temp files
OMNIVOICE_DATA_DIR=/data
# Log level: debug, info, warning, error
OMNIVOICE_LOG_LEVEL=info
# Number of uvicorn workers (1 for free tiers, 2+ for production)
OMNIVOICE_WORKERS=1

# ── Optional: Model Configuration ──
# Whisper model size: tiny, base, small, medium, large-v3
OMNIVOICE_WHISPER_MODEL=base
# Device: cpu (default) or cuda (if GPU available)
OMNIVOICE_WHISPER_DEVICE=cpu
# Default TTS language
OMNIVOICE_TTS_LANGUAGE=en
# Coqui TTS model name
OMNIVOICE_COQUI_MODEL=tts_models/multilingual/multi-dataset/xtts_v2
# Max text length for TTS
OMNIVOICE_MAX_TEXT_LENGTH=5000

# ── Optional: CORS ──
# Comma-separated list of allowed origins
OMNIVOICE_CORS_ORIGINS=http://localhost:3000,https://kivora.app

# ── Optional: Translation Fallback ──
# Groq API key for LLM-based translation fallback
GROQ_API_KEY=
