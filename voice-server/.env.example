# =============================================================================
# Kivora Voice Server - Environment Configuration
# =============================================================================
# Copy this to .env and fill in your values:
#   cp .env.example .env

# ── Required ──
HF_TOKEN=                        # HuggingFace token (needed for Pyannote diarization)

# ── Server ──
OMNIVOICE_PORT=3900              # Server port
OMNIVOICE_BIND_HOST=0.0.0.0     # Bind address
OMNIVOICE_AUTH_ENABLED=false     # Enable API key auth
OMNIVOICE_API_KEY=               # API key (if auth enabled)
OMNIVOICE_CORS_ORIGINS=http://localhost:3000,https://kivora.app

# ── Models ──
OMNIVOICE_WHISPER_MODEL=base     # base | small | medium | large-v3
OMNIVOICE_WHISPER_DEVICE=cpu     # cpu | cuda
OMNIVOICE_COQUI_MODEL=tts_models/multilingual/multi-dataset/xtts_v2
OMNIVOICE_TTS_LANGUAGE=en

# ── Data ──
OMNIVOICE_DATA_DIR=./data        # Model cache and temp files
OMNIVOICE_SAMPLE_RATE=24000
OMNIVOICE_OUTPUT_FORMAT=wav
OMNIVOICE_MAX_TEXT_LENGTH=5000
OMNIVOICE_LOG_LEVEL=info
