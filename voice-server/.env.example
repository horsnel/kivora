# =============================================================================
# Kivora Voice Server - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values before deploying.
#   cp .env.example .env
#   nano .env
# =============================================================================

# -----------------------------------------------------------------------------
# Core Server Configuration
# -----------------------------------------------------------------------------

# Public URL where the voice server is accessible (used by Kivora frontend)
VOICE_SERVER_URL=https://voice.kivora.app

# API key for authenticating requests to the voice server.
# If empty, the API is open (not recommended for production).
# Generate one with: openssl rand -hex 32
OMNIVOICE_API_KEY=

# Hugging Face token required to download gated models (e.g., Coqui TTS, Whisper)
# Get yours at: https://huggingface.co/settings/tokens
HF_TOKEN=

# -----------------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------------

# Directory inside the container where models and data are stored.
# This maps to the Docker volume for persistence.
OMNIVOICE_DATA_DIR=/data

# -----------------------------------------------------------------------------
# TTS (Text-to-Speech) Configuration
# -----------------------------------------------------------------------------

# TTS backend engine to use.
# Options: coqui | elevenlabs | openai | melotts | parler | styletts2 | bark | edge | mlx_audio | fish_speech
OMNIVOICE_TTS_BACKEND=coqui

# Coqui TTS model name (when TTS_BACKEND=coqui)
# Options: tts_models/multilingual/multi-dataset/xtts_v2, tts_models/en/ljspeech/tacotron2-DDC, etc.
OMNIVOICE_COQUI_MODEL=tts_models/multilingual/multi-dataset/xtts_v2

# Speaker reference audio for voice cloning (WAV/MP3, 10-30 seconds recommended)
# Leave empty to use the default speaker
OMNIVOICE_SPEAKER_REF=

# Language for multilingual TTS models
# Options: en | es | fr | de | it | pt | pl | tr | ru | nl | cs | ar | zh | ja | ko | hu | ko
OMNIVOICE_TTS_LANGUAGE=en

# MLX Audio model (Apple Silicon only, when TTS_BACKEND=mlx_audio)
# Options: mlx-community/csm-1b | performantlabs/csm-1b-mlx
OMNIVOICE_MLX_AUDIO_MODEL=mlx-community/csm-1b

# ElevenLabs API key (when TTS_BACKEND=elevenlabs)
ELEVENLABS_API_KEY=

# OpenAI API key (when TTS_BACKEND=openai)
OPENAI_API_KEY=

# Fish Speech model path (when TTS_BACKEND=fish_speech)
OMNIVOICE_FISH_MODEL=fish-speech-1.5

# -----------------------------------------------------------------------------
# ASR (Automatic Speech Recognition) Configuration
# -----------------------------------------------------------------------------

# ASR backend engine to use.
# Options: whisper | faster_whisper | deepgram | azure | google
OMNIVOICE_ASR_BACKEND=whisper

# Whisper model size (when ASR_BACKEND=whisper or faster_whisper)
# Options: tiny | base | small | medium | large | large-v2 | large-v3 | turbo
OMNIVOICE_WHISPER_MODEL=large-v3

# Whisper compute device
# Options: cpu | cuda | auto
OMNIVOICE_WHISPER_DEVICE=auto

# Deepgram API key (when ASR_BACKEND=deepgram)
DEEPGRAM_API_KEY=

# Azure Speech key (when ASR_BACKEND=azure)
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# Google Cloud credentials path (when ASR_BACKEND=google)
GOOGLE_APPLICATION_CREDENTIALS=

# -----------------------------------------------------------------------------
# Audio Processing
# -----------------------------------------------------------------------------

# Default output sample rate (Hz)
OMNIVOICE_SAMPLE_RATE=24000

# Default output audio format
# Options: wav | mp3 | ogg | flac | pcm
OMNIVOICE_OUTPUT_FORMAT=wav

# Maximum input audio duration in seconds for ASR
OMNIVOICE_MAX_AUDIO_DURATION=300

# Maximum text length for TTS (characters)
OMNIVOICE_MAX_TEXT_LENGTH=5000

# -----------------------------------------------------------------------------
# Server Performance
# -----------------------------------------------------------------------------

# Number of Uvicorn worker processes
# CPU: 1-2, GPU: 1 (GPU doesn't benefit from multiple workers)
OMNIVOICE_WORKERS=1

# Logging level
# Options: debug | info | warning | error | critical
OMNIVOICE_LOG_LEVEL=info

# Bind host (0.0.0.0 for all interfaces, 127.0.0.1 for local only)
OMNIVOICE_BIND_HOST=0.0.0.0

# Server port
OMNIVOICE_PORT=3900

# -----------------------------------------------------------------------------
# GPU Configuration (GPU profile only)
# -----------------------------------------------------------------------------

# NVIDIA GPU device indices (comma-separated, or "all")
NVIDIA_VISIBLE_DEVICES=all

# CUDA memory fraction to allocate (0.0 - 1.0)
# Lower values leave VRAM for other processes
OMNIVOICE_CUDA_MEMORY_FRACTION=0.9

# -----------------------------------------------------------------------------
# Caddy / Reverse Proxy
# -----------------------------------------------------------------------------

# Domain for automatic HTTPS (leave empty for local development)
VOICE_DOMAIN=voice.kivora.app

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------

# Enable API key authentication (set to true in production)
OMNIVOICE_AUTH_ENABLED=true

# Allowed origins for CORS (comma-separated)
OMNIVOICE_CORS_ORIGINS=https://kivora.app,https://www.kivora.app

# Rate limit: max requests per second per IP
OMNIVOICE_RATE_LIMIT=30

# Rate limit for TTS endpoint specifically (lower due to GPU cost)
OMNIVOICE_TTS_RATE_LIMIT=10
