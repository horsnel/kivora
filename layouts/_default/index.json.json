{{- $.Scratch.Add "index" slice -}}
{{- range .Site.RegularPages -}}
{{- $.Scratch.Add "index" (dict "title" .Title "permalink" .Permalink "summary" .Summary "categories" .Params.category "tags" .Params.tags "date" (.Date.Format "2006-01-02") "image" .Params.image) -}}
{{- end -}}
{{- $.Scratch.Get "index" | jsonify -}}