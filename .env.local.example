# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-key-here
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Groq ──────────────────────────────────────────────────────
GROQ_API_KEY=gsk_your-groq-api-key

# ── Web Search Providers ─────────────────────────────────────
# The chat web_search tool runs Tavily + Brave + Firecrawl + DuckDuckGo in parallel.
# Tavily has a hardcoded fallback key. DuckDuckGo needs no key.
# Brave Search — optional, higher quality results (https://brave.com/search/api/)
BRAVE_SEARCH_API_KEY=
# Firecrawl — has hardcoded fallback key, no setup needed unless you want your own
FIRECRAWL_API_KEY=

# ── PostHog Analytics ─────────────────────────────────────────
# Get these from https://app.posthog.com/project/settings
NEXT_PUBLIC_POSTHOG_KEY=phc_your-project-api-key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# Server-side only — needed for Dashboard Progress tab
POSTHOG_PERSONAL_API_KEY=phx_your-personal-api-key
POSTHOG_PROJECT_ID=your-project-id

# ── Site URL (update after Cloudflare deploy) ─────────────────
NEXT_PUBLIC_SITE_URL=https://kivora.pages.dev

# ── Code Execution Backends (4 backends with smart auto-routing) ──
# The run_code and run_on_gpu tools auto-select the best available backend.
# Set up at least one. Kaggle is easiest for GPU, E2B is fastest for CPU.

# ── E2B (Fastest CPU execution — 150ms cold start) ──
# Get your API key at: https://e2b.dev/dashboard?tab=keys
# Firecracker microVMs with Jupyter, supports Python/JS/R/Java/Bash
# Free: $100 credits on signup
E2B_API_KEY=e2b_your-api-key

# ── Kaggle (Free GPU — recommended for ML) ──
# Get your API key at: https://www.kaggle.com/settings → API → Create New Token
# Free: T4 GPU, P100 GPU, TPU v3-8 (30h/week)
KAGGLE_USERNAME=your-kaggle-username
KAGGLE_KEY=your-kaggle-api-key

# ── Google Colab (Premium GPUs) ──
# Requires OAuth setup at: https://console.cloud.google.com/apis/credentials
# Supports: T4/L4/A100/H100 GPUs, v5e1/v6e1/V2-8 TPUs
GOOGLE_COLAB_CLIENT_ID=your-google-oauth-client-id
GOOGLE_COLAB_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_COLAB_ACCESS_TOKEN=

# ── GitHub Codespaces (Full dev environment) ──
# GitHub PAT with 'codespace' scope
# Up to 64GB RAM, any language, persistent devcontainers
# Free: 120 core-hours/month
GITHUB_TOKEN=ghp_your-github-token
