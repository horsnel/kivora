# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-key-here
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Groq ──────────────────────────────────────────────────────
GROQ_API_KEY=gsk_your-groq-api-key

# ── PostHog Analytics ─────────────────────────────────────────
# Get these from https://app.posthog.com/project/settings
NEXT_PUBLIC_POSTHOG_KEY=phc_your-project-api-key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# Server-side only — needed for Dashboard Progress tab
POSTHOG_PERSONAL_API_KEY=phx_your-personal-api-key
POSTHOG_PROJECT_ID=your-project-id

# ── Site URL (update after Cloudflare deploy) ─────────────────
NEXT_PUBLIC_SITE_URL=https://kivora.pages.dev

# ── Google Colab CLI Integration ──────────────────────────────
# Required for GPU/TPU execution via Google Colab
# Get these from: https://console.cloud.google.com/apis/credentials
# OAuth 2.0 Client ID (for user-facing auth flow)
GOOGLE_COLAB_CLIENT_ID=your-google-oauth-client-id
# OAuth 2.0 Client Secret (for token exchange in callback)
GOOGLE_COLAB_CLIENT_SECRET=your-google-oauth-client-secret
# Optional: Pre-authorized access token for agent-driven GPU jobs
# If set, the chat AI can use run_on_gpu without user OAuth
GOOGLE_COLAB_ACCESS_TOKEN=
