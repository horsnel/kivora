# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-key-here
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Groq ──────────────────────────────────────────────────────
GROQ_API_KEY=gsk_your-groq-api-key

# ── Web Search Providers ─────────────────────────────────────
# The chat web_search tool runs Tavily + Brave + Firecrawl + DuckDuckGo in parallel.
# Tavily has a hardcoded fallback key. DuckDuckGo needs no key.
# Brave Search — optional, higher quality results (https://brave.com/search/api/)
BRAVE_SEARCH_API_KEY=
# Firecrawl — has hardcoded fallback key, no setup needed unless you want your own
FIRECRAWL_API_KEY=

# ── PostHog Analytics ─────────────────────────────────────────
# Get these from https://app.posthog.com/project/settings
NEXT_PUBLIC_POSTHOG_KEY=phc_your-project-api-key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# Server-side only — needed for Dashboard Progress tab
POSTHOG_PERSONAL_API_KEY=phx_your-personal-api-key
POSTHOG_PROJECT_ID=your-project-id

# ── Site URL (update after Cloudflare deploy) ─────────────────
NEXT_PUBLIC_SITE_URL=https://kivora.pages.dev

# ── Code Execution Backends (6 backends with smart auto-routing) ──
# The run_code and run_on_gpu tools auto-select the best available backend.
# Priority: Daytona → Docker → E2B → Kaggle → Colab → Codespaces

# ── Daytona (Primary — real shell, persistent sandboxes, GPU) ──
# Get your API key at: https://app.daytona.io/dashboard/keys
# Sub-90ms cold start, real terminal access, full filesystem, persistent sessions
# GPU: H100, RTX Pro 6000 | Self-hostable (AGPL 3.0)
# Free: $200 credits on signup
DAYTONA_API_KEY=dpt_your-api-key
# Optional: Override API URL (for self-hosted instances)
# DAYTONA_API_URL=https://app.daytona.io/api

# ── Docker Sandbox (Self-hosted — universal, any VPS with Docker) ──
# Works with any Docker host: Docker Desktop, VPS, Docker-in-Docker, etc.
# Full container lifecycle, any language, persistent containers, filesystem ops.
# Best for: Self-hosted sandboxes, full control over resources and images.
# For security, use a docker-socket-proxy (e.g. Tecnativa) instead of
# exposing the raw Docker socket. Never expose port 2375/2376 to the public internet.
DOCKER_HOST_URL=http://your-docker-host:2375
# For TLS-secured Docker hosts:
# DOCKER_TLS_CA=-----BEGIN CERTIFICATE-----...-----END CERTIFICATE-----
# DOCKER_TLS_CERT=-----BEGIN CERTIFICATE-----...-----END CERTIFICATE-----
# DOCKER_TLS_KEY=-----BEGIN PRIVATE KEY-----...-----END PRIVATE KEY-----

# ── E2B (Fast ephemeral CPU — 150ms cold start) ──
# Get your API key at: https://e2b.dev/dashboard?tab=keys
# Firecracker microVMs with Jupyter, supports Python/JS/R/Java/Bash
# Free: $100 credits on signup
E2B_API_KEY=e2b_your-api-key

# ── Kaggle (Free GPU — recommended for ML) ──
# Get your API key at: https://www.kaggle.com/settings → API → Create New Token
# Free: T4 GPU, P100 GPU, TPU v3-8 (30h/week)
KAGGLE_USERNAME=your-kaggle-username
KAGGLE_KEY=your-kaggle-api-key

# ── Google Colab (Premium GPUs) ──
# Requires OAuth setup at: https://console.cloud.google.com/apis/credentials
# Supports: T4/L4/A100/H100 GPUs, v5e1/v6e1/V2-8 TPUs
GOOGLE_COLAB_CLIENT_ID=your-google-oauth-client-id
GOOGLE_COLAB_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_COLAB_ACCESS_TOKEN=

# ── GitHub Codespaces (Full dev environment + code execution fallback) ──
# GitHub PAT with 'codespace', 'repo', and 'workflow' scopes
# Up to 64GB RAM, any language, persistent devcontainers
# Free: 120 core-hours/month
# Used as fallback when E2B is unavailable — executes code via GitHub Actions
GITHUB_TOKEN=ghp_your-github-token
# Default repository for Codespaces execution (owner/repo format)
# The repo must be accessible with your GITHUB_TOKEN
GITHUB_DEFAULT_REPO=your-github-username/your-repo

# ── Cloudflare Pages Deployment ──
# CF_API_TOKEN is required. CF_ACCOUNT_ID is auto-detected from the token.
# If auto-detection fails, set CF_ACCOUNT_ID explicitly.
CF_API_TOKEN=your-cloudflare-api-token
CF_ACCOUNT_ID=
